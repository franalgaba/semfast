{
  "name": "@semfast/semfast",
  "version": "0.1.0",
  "description": "Local-first Semfast retrieval runtime for Bun and Hono",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franalgaba/semfast.git",
    "directory": "packages/semfast-node"
  },
  "bugs": {
    "url": "https://github.com/franalgaba/semfast/issues"
  },
  "homepage": "https://github.com/franalgaba/semfast#readme",
  "keywords": [
    "semantic-search",
    "retrieval",
    "rag",
    "voice-agents",
    "hono",
    "bun",
    "turbovec"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "native/*.node",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build:native && bun run build:ts",
    "build:native": "bun scripts/build-native.mjs",
    "build:ts": "bunx tsc -p tsconfig.json",
    "test": "bun run build:native && bun test ./test/*.test.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "bench": "bun run src/benchmark-cli.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "hono": "^4.12.25"
  }
}
