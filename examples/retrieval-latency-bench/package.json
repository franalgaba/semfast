{
  "name": "@semfast/retrieval-latency-bench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:semfast": "cd ../../packages/semfast-node && bun run build",
    "prepare:benchmark": "bun run scripts/prepare-scifact.ts",
    "build:index": "bun run scripts/build-benchmark-index.ts",
    "dev": "vite --host 127.0.0.1",
    "dev:api": "bun run server/index.ts",
    "build": "vite build",
    "smoke": "bun run server/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "bun run prepare:semfast && bun run prepare:benchmark && bun run build:index && bun run typecheck && bun run build && SEMFAST_INDEX_PATH=data/index bun run smoke"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "typescript": "^5.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "hono": "^4.12.25",
    "@semfast/semfast": "file:../../packages/semfast-node"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
